{
  "expo": {
    "name": "MindCare",
    "slug": "agentic-mental-care",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "icon": "./assets/icon.png",
      "supportsTabletMode": true,
      "bundleIdentifier": "com.mentalcare.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2A7FBF"
      },
      "package": "com.mentalcare.app",
      "enableUrlQueryStringSupport": false
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2A7FBF"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "color": "#2A7FBF"
        }
      ]
    ],
    "jsEngine": "hermes",
    "extra": {
      "eas": {
        "projectId": "50ea4c14-acf7-4c2b-a5ee-f7beee19c4ee"
      }
    }
  }
}
