# Firebase Configuration
# Copy your actual values from Firebase Console → Project Settings → Your apps → Web
# DO NOT commit this file with real credentials!

EXPO_PUBLIC_FIREBASE_API_KEY=YOUR_API_KEY
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=YOUR_PROJECT_ID
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=YOUR_MESSAGING_SENDER_ID
EXPO_PUBLIC_FIREBASE_APP_ID=YOUR_APP_ID

# Example with actual format (DO NOT USE REAL VALUES):
# EXPO_PUBLIC_FIREBASE_API_KEY=AIzaSyDXx-AqKLqqe_K_wU_C8zXxkFz-5Y7h9oo
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=agentic-mental-care.firebaseapp.com
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=agentic-mental-care
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=agentic-mental-care.appspot.com
# EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
# EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456abcd
